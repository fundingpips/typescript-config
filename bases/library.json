{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "FundingPips Library",
  "_comment": [
    "For publishable TS/React libraries. Extends base and adds emit/declaration settings.",
    "Only declares settings that differ from ./base.json."
  ],
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./dist/types",
    "outDir": "./dist",
    "rootDir": "./src",
    "stripInternal": true,
    "composite": true,

    "allowImportingTsExtensions": false,
    "types": []
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/*.stories.ts",
    "**/*.stories.tsx"
  ]
}
