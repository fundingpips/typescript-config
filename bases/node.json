{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "FundingPips Node.js (CommonJS)",
  "_comment": [
    "CommonJS Node.js services. Extends base; overrides module system to CJS.",
    "For new services prefer ./node-esm.json unless CJS is required.",
    "include/exclude live in the consumer tsconfig (paths resolve relative",
    "to the declaring file)."
  ],
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2024"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,

    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "removeComments": true,
    "outDir": "./dist",
    "rootDir": "./src",

    "types": ["node"]
  }
}
