{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "FundingPips React Native",
  "_comment": [
    "Targets React Native 0.83+ with Hermes. Extends base; overrides JSX,",
    "module resolution, and customConditions for the RN bundler.",
    "Keeps allowJs: true because some RN native modules still ship .js files.",
    "Testing framework is Jest (React Native ecosystem default)."
  ],
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-native",

    "moduleResolution": "bundler",
    "customConditions": ["react-native"],
    "allowImportingTsExtensions": true,
    "allowArbitraryExtensions": true,
    "resolvePackageJsonImports": false,

    "allowJs": true,
    "checkJs": false,
    "forceConsistentCasingInFileNames": false,

    "types": ["jest"]
  },
  "include": ["src", "index.js", ".monicon/*.d.ts"],
  "exclude": ["node_modules", "android", "ios", "build", "coverage", "**/Pods/**"]
}
