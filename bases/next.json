{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "FundingPips Next.js",
  "_comment": [
    "Only declares settings that differ from ./base.json.",
    "Everything else inherits; if base changes, consumers pick it up."
  ],
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "allowJs": false,
    "checkJs": false,
    "allowImportingTsExtensions": false
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/**/*"],
  "exclude": ["node_modules", ".next", "out", "public", "*.config.js", "*.config.mjs"]
}
