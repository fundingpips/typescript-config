{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "FundingPips Vite React",
  "_comment": [
    "Vite React apps. Extends base; adds DOM libs and Vite-specific settings.",
    "`erasableSyntaxOnly` (TS 5.8+) enforces compatibility with Node's native",
    "TypeScript stripping — no `enum`, namespace code, or parameter properties."
  ],
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    "moduleDetection": "force",
    "useDefineForClassFields": true,
    "erasableSyntaxOnly": true,

    "allowJs": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts", "vite.config.js"],
  "exclude": ["node_modules", "dist", "build", "coverage"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
