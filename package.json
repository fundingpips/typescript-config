{
  "name": "@fundingpips/typescript-config",
  "version": "2.1.0",
  "description": "Shareable TypeScript configurations for FundingPips projects",
  "keywords": [
    "config",
    "fundingpips",
    "nextjs",
    "node",
    "react-native",
    "tsconfig",
    "typescript"
  ],
  "homepage": "https://github.com/fundingpips/typescript-config#readme",
  "bugs": {
    "url": "https://github.com/fundingpips/typescript-config/issues"
  },
  "license": "MIT",
  "author": "FundingPips",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fundingpips/typescript-config.git"
  },
  "files": [
    "bases"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./bases/base.json"
    },
    "./package.json": "./package.json",
    "./base": "./bases/base.json",
    "./next": "./bases/next.json",
    "./react-native": "./bases/react-native.json",
    "./node": "./bases/node.json",
    "./node-esm": "./bases/node-esm.json",
    "./library": "./bases/library.json",
    "./vite": "./bases/vite.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepare": "husky",
    "release": "npm publish --access public",
    "test": "bash scripts/validate-all.sh",
    "test:config": "bash scripts/validate-config.sh"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.46.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "typescript": ">=5.9.0"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@10.33.1+sha512.Bbo8HV0cGPaN8GRw10BV5i1B/BEKDGYNsbLfsnhTJ/BM8PaDRdRgm8Ugief6A0PDFZOy+VlOLF1dpCYjCsyYIA=="
}
